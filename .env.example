# ===== Application =====
APP_NAME=ContextFlow
ENVIRONMENT=local

# ===== PostgreSQL =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contextflow_dev

# ===== Redis =====
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ===== Auth / JWT =====
SECRET_KEY=super-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== AI Provider =====
# Provider: "openai" | "google" | "openrouter"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini

# OpenAI / OpenRouter API key
OPENAI_API_KEY=sk-...
# Only needed for OpenRouter (leave blank for direct OpenAI):
OPENAI_BASE_URL=

# Google Gemini API key (only needed if LLM_PROVIDER=google)
GOOGLE_API_KEY=

# ===== Embeddings =====
# Provider: "openai" or "huggingface"
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# For HuggingFace: EMBEDDING_PROVIDER=huggingface, EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2, EMBEDDING_DIMENSIONS=384
HUGGINGFACE_API_KEY=

# ===== LiveKit =====
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_key
LIVEKIT_API_SECRET=your_livekit_secret

# ===== Internal RAG Service Auth =====
# Shared token used only by trusted internal workers (for example the LiveKit voice worker)
# when they need to call user-scoped RAG/context endpoints.
RAG_SERVICE_TOKEN=

# ===== Observability (LangSmith) =====
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT=contextflow_dev
